{
  "info": {
    "name": "AgriAssist Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for AgriAssist production backend"
  },
  "item": [
    {
      "name": "Auth - Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Buyer One\",\n  \"email\": \"buyer@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"buyer\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"Password@123\"\n}"
        }
      }
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
      }
    },
    {
      "name": "Products - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Organic Wheat\",\n  \"category\": \"grain\",\n  \"description\": \"Premium quality\",\n  \"price\": 30,\n  \"quantity\": 100,\n  \"commodity\": \"wheat\",\n  \"msp\": 22,\n  \"localDemandIndex\": 1.2,\n  \"localSupplyIndex\": 0.9\n}"
        }
      }
    },
    {
      "name": "Prices - Suggest",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/prices/suggest", "host": ["{{baseUrl}}"], "path": ["prices", "suggest"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"commodity\": \"rice\",\n  \"msp\": 18,\n  \"localDemandIndex\": 1.4,\n  \"localSupplyIndex\": 0.7\n}"
        }
      }
    },
    {
      "name": "Orders - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [{\"productId\": \"{{productId}}\", \"quantity\": 2}],\n  \"shippingAddress\": \"Village Road, Pune\"\n}"
        }
      }
    },
    {
      "name": "Payments - Create Razorpay Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/payments/create-order", "host": ["{{baseUrl}}"], "path": ["payments", "create-order"] },
        "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}" }
      }
    },
    {
      "name": "KYC - Upload",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/kyc/upload", "host": ["{{baseUrl}}"], "path": ["kyc", "upload"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"kycDocumentUrl\": \"https://example.com/kyc.pdf\",\n  \"ocrText\": \"1234 5678 9012\"\n}"
        }
      }
    },
    {
      "name": "Admin - Analytics",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": { "raw": "{{baseUrl}}/admin/analytics", "host": ["{{baseUrl}}"], "path": ["admin", "analytics"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
  ]
}
